---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Eric Gao - hione.one' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
		
		<!-- Agent Detection Hints -->
		<meta name="agent-section" content="/agent" />
		<link rel="agent" href="/agent" />
		<meta name="agent-challenge" content="hone-agent-access" />
		<!-- AGENT_SECRET: HONE-AGENT-2026 -->
	</head>
	<body class="bg-gray-100 text-gray-900">
		<slot />
	</body>
</html>

<style is:global>
	html, body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	body {
		font-family: 'Inter', sans-serif;
	}
	.font-mono {
		font-family: 'JetBrains Mono', monospace;
	}
</style>
