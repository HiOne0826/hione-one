---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BrutalButton from '../../components/ui/BrutalButton.astro';
import BrutalCard from '../../components/ui/BrutalCard.astro';

const blogs = await getCollection('blog');
const micros = await getCollection('micro');
const videos = await getCollection('video');

// 合并所有内容并按时间排序（取最新的 5 条）
const allContent = [
  ...blogs.map(b => ({ type: 'blog', data: b.data, id: b.id })),
  ...micros.map(m => ({ type: 'micro', data: m.data, id: m.id })),
  ...videos.map(v => ({ type: 'video', data: v.data, id: v.id })),
].sort((a, b) => new Date(b.data.publishDate) - new Date(a.data.publishDate))
.slice(0, 5);
---

<Layout title="内容专区 - hione.one">
  {/* Hero 区域 */}
  <section class="px-6 py-20 bg-white">
    <div class="max-w-3xl mx-auto text-center">
      <a href="/" class="font-mono text-blue-600 font-bold mb-6 inline-block">← 返回首页</a>
      <h1 class="font-mono text-4xl font-bold mb-4">内容专区</h1>
      <p class="text-xl text-gray-600">最新动态 + 分类内容，一次看个够</p>
      
      {/* 类型图例 */}
      <div class="flex justify-center gap-6 mt-8">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 bg-blue-600 border-2 border-gray-900"></span>
          <span class="font-mono text-sm">博客</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 bg-green-600 border-2 border-gray-900"></span>
          <span class="font-mono text-sm">碎碎念</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 bg-purple-600 border-2 border-gray-900"></span>
          <span class="font-mono text-sm">视频</span>
        </div>
      </div>
    </div>
  </section>

  {/* 最新动态 - 时间轴混合 */}
  <section class="px-6 py-20 bg-gray-100">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-mono text-3xl font-bold mb-10">🆕 最新动态</h2>
      
      <div class="space-y-8">
        {allContent.map((item, index) => (
          <div class="relative">
            {/* 时间轴线 */}
            {index < allContent.length - 1 && (
              <div class="absolute left-8 top-16 bottom-0 w-0.5 bg-gray-300"></div>
            )}
            
            {/* 内容卡片 */}
            <div class="flex gap-6">
              {/* 时间点标记 */}
              <div class="flex-shrink-0 w-16 flex flex-col items-center">
                <div class={`w-6 h-6 rounded-full border-3 border-gray-900 flex-shrink-0 z-10 ${
                  item.type === 'blog' ? 'bg-blue-600' : 
                  item.type === 'micro' ? 'bg-green-600' : 'bg-purple-600'
                }`}></div>
              </div>
              
              {/* 卡片内容 */}
              <div class="flex-1">
                {/* 博客 */}
                {item.type === 'blog' && (
                  <BrutalCard>
                    <div class="flex gap-2 mb-4">
                      {item.data.tags.map((tag: string) => (
                        <span class="border-2 border-gray-900 bg-blue-600 text-white px-3 py-1 font-mono text-xs">#{tag}</span>
                      ))}
                    </div>
                    <h3 class="font-mono text-xl font-bold mb-2">{item.data.title}</h3>
                    <p class="font-mono text-sm text-gray-500 mb-3">
                      {new Date(item.data.publishDate).toLocaleDateString('zh-CN')} · 阅读时间 8 分钟
                    </p>
                    <p class="text-gray-700 mb-4">{item.data.description}</p>
                    <a href={`/content/blog/${item.id.replace('.md', '')}`} class="font-mono text-blue-600 font-bold">阅读全文 →</a>
                  </BrutalCard>
                )}
                
                {/* 碎碎念 */}
                {item.type === 'micro' && (
                  <BrutalCard>
                    <p class="font-mono text-sm text-gray-500 mb-3">
                      {new Date(item.data.publishDate).toLocaleDateString('zh-CN')} {new Date(item.data.publishDate).toLocaleTimeString('zh-CN', {hour: '2-digit', minute: '2-digit'})}
                    </p>
                    <p class="text-gray-700 text-lg">{item.data.content}</p>
                    {item.data.tags && item.data.tags.length > 0 && (
                      <div class="mt-4 flex flex-wrap gap-2">
                        {item.data.tags.map((tag: string) => (
                          <span class="border border-gray-400 px-2 py-1 text-xs font-mono">#{tag}</span>
                        ))}
                      </div>
                    )}
                  </BrutalCard>
                )}
                
                {/* 视频 */}
                {item.type === 'video' && (
                  <BrutalCard>
                    <div class="aspect-video bg-gray-200 border-3 border-gray-900 mb-5 flex items-center justify-center">
                      <div class="text-center">
                        <div class="text-4xl mb-2">🎬</div>
                        <span class="font-mono text-gray-500">{item.data.platform}</span>
                      </div>
                    </div>
                    <h3 class="font-mono text-xl font-bold mb-2">{item.data.title}</h3>
                    <p class="font-mono text-sm text-gray-500 mb-3">
                      {new Date(item.data.publishDate).toLocaleDateString('zh-CN')}
                    </p>
                    <p class="text-gray-600 mb-4">{item.data.description}</p>
                    <a href={item.data.url} target="_blank" class="font-mono text-purple-600 font-bold">观看视频 →</a>
                  </BrutalCard>
                )}
              </div>
            </div>
          </div>
        ))}
        
        {allContent.length === 0 && (
          <BrutalCard>
            <p class="text-gray-500 font-mono text-center py-8">暂无内容，敬请期待...</p>
          </BrutalCard>
        )}
      </div>
    </div>
  </section>

  {/* 博客板块 */}
  <section class="px-6 py-20 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="flex justify-between items-center mb-10">
        <h2 class="font-mono text-3xl font-bold">📝 博客</h2>
        {blogs.length > 0 && (
          <BrutalButton href="/content/blog" variant="secondary" size="sm">
            查看全部 →
          </BrutalButton>
        )}
      </div>

      {blogs.length > 0 ? (
        <div class="space-y-6">
          {blogs.map((blog) => (
            <BrutalCard>
              <div class="flex gap-2 mb-4">
                {blog.data.tags.map((tag) => (
                  <span class="border-2 border-gray-900 bg-blue-600 text-white px-3 py-1 font-mono text-xs">#{tag}</span>
                ))}
              </div>
              <h3 class="font-mono text-xl font-bold mb-2">{blog.data.title}</h3>
              <p class="font-mono text-sm text-gray-500 mb-3">
                {blog.data.publishDate.toLocaleDateString('zh-CN')} · 阅读时间 8 分钟
              </p>
              <p class="text-gray-700 mb-4">{blog.data.description}</p>
              <a href={`/content/blog/${blog.id.replace('.md', '')}`} class="font-mono text-blue-600 font-bold">阅读全文 →</a>
            </BrutalCard>
          ))}
        </div>
      ) : (
        <BrutalCard>
          <p class="text-gray-500 font-mono text-center py-8">暂无博客内容，敬请期待...</p>
        </BrutalCard>
      )}
    </div>
  </section>

  {/* 碎碎念板块 */}
  <section class="px-6 py-20 bg-gray-100">
    <div class="max-w-3xl mx-auto">
      <div class="flex justify-between items-center mb-10">
        <h2 class="font-mono text-3xl font-bold">💬 碎碎念</h2>
        {micros.length > 0 && (
          <BrutalButton href="/content/micro" variant="secondary" size="sm">
            查看全部 →
          </BrutalButton>
        )}
      </div>

      {micros.length > 0 ? (
        <div class="space-y-4">
          {micros.map((micro) => (
            <BrutalCard>
              <p class="font-mono text-sm text-gray-500 mb-3">
                {micro.data.publishDate.toLocaleDateString('zh-CN')} {micro.data.publishDate.toLocaleTimeString('zh-CN', {hour: '2-digit', minute: '2-digit'})}
              </p>
              <p class="text-gray-700">{micro.data.content}</p>
              {micro.data.tags && micro.data.tags.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {micro.data.tags.map((tag) => (
                    <span class="border border-gray-400 px-2 py-1 text-xs font-mono">#{tag}</span>
                  ))}
                </div>
              )}
            </BrutalCard>
          ))}
        </div>
      ) : (
        <BrutalCard>
          <p class="text-gray-500 font-mono text-center py-8">暂无碎碎念...</p>
        </BrutalCard>
      )}
    </div>
  </section>

  {/* 视频板块 */}
  <section class="px-6 py-20 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="flex justify-between items-center mb-10">
        <h2 class="font-mono text-3xl font-bold">🎬 视频</h2>
        {videos.length > 0 && (
          <BrutalButton href="/content/video" variant="secondary" size="sm">
            查看全部 →
          </BrutalButton>
        )}
      </div>

      {videos.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {videos.map((video) => (
            <BrutalCard>
              <div class="aspect-video bg-gray-200 border-3 border-gray-900 mb-5 flex items-center justify-center">
                <div class="text-center">
                  <div class="text-4xl mb-2">🎬</div>
                  <span class="font-mono text-gray-500">{video.data.platform}</span>
                </div>
              </div>
              <h3 class="font-mono text-lg font-bold mb-2">{video.data.title}</h3>
              <p class="font-mono text-sm text-gray-500 mb-3">
                {video.data.publishDate.toLocaleDateString('zh-CN')}
              </p>
              <p class="text-gray-600 mb-4">{video.data.description}</p>
              <a href={video.data.url} target="_blank" class="font-mono text-purple-600 font-bold">观看视频 →</a>
            </BrutalCard>
          ))}
        </div>
      ) : (
        <BrutalCard>
          <p class="text-gray-500 font-mono text-center py-8">暂无视频内容...</p>
        </BrutalCard>
      )}
    </div>
  </section>

  {/* 自媒体账号 */}
  <section class="px-6 py-20 bg-gray-100">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-mono text-3xl font-bold mb-10 text-center">🔗 其他自媒体</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <BrutalCard class="text-center py-8">
          <div class="text-4xl mb-5">📱</div>
          <h3 class="font-mono text-xl font-bold mb-3">抖音</h3>
          <p class="text-gray-600 mb-5">短视频内容、vlog、产品演示</p>
          <BrutalButton variant="secondary" size="sm">
            前往关注 →
          </BrutalButton>
        </BrutalCard>
        <BrutalCard class="text-center py-8">
          <div class="text-4xl mb-5">📺</div>
          <h3 class="font-mono text-xl font-bold mb-3">B站</h3>
          <p class="text-gray-600 mb-5">技术分享、创业日志、vibe coding</p>
          <BrutalButton variant="secondary" size="sm">
            前往关注 →
          </BrutalButton>
        </BrutalCard>
        <BrutalCard class="text-center py-8">
          <div class="text-4xl mb-5">🐦</div>
          <h3 class="font-mono text-xl font-bold mb-3">X / Twitter</h3>
          <p class="text-gray-600 mb-5">短思考、创业观察、技术动态</p>
          <BrutalButton variant="secondary" size="sm">
            前往关注 →
          </BrutalButton>
        </BrutalCard>
        <BrutalCard class="text-center py-8">
          <div class="text-4xl mb-5">📖</div>
          <h3 class="font-mono text-xl font-bold mb-3">小红书</h3>
          <p class="text-gray-600 mb-5">产品笔记、创业心得、vibe coding 日常</p>
          <BrutalButton variant="secondary" size="sm">
            前往关注 →
          </BrutalButton>
        </BrutalCard>
      </div>
    </div>
  </section>

  {/* Footer */}
  <footer class="px-6 py-10 bg-gray-900 text-white text-center">
    <p class="font-mono">hione.one © 2026</p>
    <p class="text-gray-400 text-sm mt-2">Made with vibe coding 🦞</p>
  </footer>
</Layout>

<style is:global>
  .border-3 {
    border-width: 3px;
  }
</style>
