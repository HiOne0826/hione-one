---
import { getCollection } from 'astro:content';
import BrutalButton from '../../../components/ui/BrutalButton.astro';
import BrutalCard from '../../../components/ui/BrutalCard.astro';

export async function getStaticPaths() {
  const blogs = await getCollection('blog');
  return blogs.map((blog) => ({
    params: { slug: blog.id },
  }));
}

const { slug } = Astro.params;
const blogs = await getCollection('blog');
const blog = blogs.find((b) => b.id === slug);

if (!blog) {
  return Astro.redirect('/content');
}
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{blog.data.title} - hione.one</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      .font-mono {
        font-family: 'JetBrains Mono', monospace;
      }
      .brutal-border {
        border: 3px solid #1A1A1A;
      }
      .brutal-shadow {
        box-shadow: 4px 4px 0px #1A1A1A;
      }
      .tag {
        border: 2px solid #1A1A1A;
        background: #0066FF;
        color: white;
        padding: 2px 8px;
      }
    </style>
  </head>
  <body class="bg-gray-100 text-gray-900">

    {/* Hero 区域 */}
    <section class="px-6 py-20 bg-white">
      <div class="max-w-3xl mx-auto">
        <a href="/content" class="font-mono text-blue-600 font-bold mb-6 inline-block hover:underline">← 返回内容专区</a>
        <div class="flex flex-wrap gap-2 mb-6">
          {blog.data.tags.map((tag) => (
            <span class="tag font-mono text-xs">#{tag}</span>
          ))}
        </div>
        <h1 class="font-mono text-4xl md:text-5xl font-bold mb-4">{blog.data.title}</h1>
        <p class="font-mono text-sm text-gray-500 mb-6">
          {blog.data.publishDate.toLocaleDateString('zh-CN')} · 阅读时间 8 分钟
          {blog.data.updatedDate && ` · 更新于 ${blog.data.updatedDate.toLocaleDateString('zh-CN')}`}
        </p>
        <p class="text-xl text-gray-600 mb-8 leading-relaxed">{blog.data.description}</p>
      </div>
    </section>

    {/* 博客内容 */}
    <section class="px-6 py-16">
      <div class="max-w-3xl mx-auto">
        <BrutalCard class="p-8">
          <div class="prose prose-lg max-w-none">
            <p class="text-gray-700 leading-relaxed mb-6">
              博客内容正在整理中...
            </p>
          </div>
        </BrutalCard>
      </div>
    </section>

    {/* Footer */}
    <footer class="px-6 py-10 bg-gray-900 text-white text-center">
      <p class="font-mono">hione.one © 2026</p>
      <p class="text-gray-400 text-sm mt-2">Made with vibe coding 🦞</p>
    </footer>

  </body>
</html>
