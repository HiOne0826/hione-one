---
import { getCollection } from 'astro:content';
import BrutalButton from '../../components/ui/BrutalButton.astro';
import BrutalCard from '../../components/ui/BrutalCard.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { id: project.id },
  }));
}

const { id } = Astro.params;
const projects = await getCollection('projects');
const project = projects.find((p) => p.id === id);

if (!project) {
  return Astro.redirect('/');
}
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{project.data.title} - hione.one</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      .font-mono {
        font-family: 'JetBrains Mono', monospace;
      }
      .brutal-border {
        border: 3px solid #1A1A1A;
      }
      .brutal-shadow {
        box-shadow: 4px 4px 0px #1A1A1A;
      }
      .brutal-btn {
        border: 3px solid #1A1A1A;
        box-shadow: 4px 4px 0px #1A1A1A;
        transition: all 0.1s ease;
      }
      .brutal-btn:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0px #1A1A1A;
      }
      .brutal-btn:active {
        transform: translate(2px, 2px);
        box-shadow: 2px 2px 0px #1A1A1A;
      }
      .tag {
        border: 2px solid #1A1A1A;
        background: #0066FF;
        color: white;
        padding: 2px 8px;
      }
      .tag-secondary {
        border: 2px solid #1A1A1A;
        background: white;
        color: #1A1A1A;
        padding: 2px 8px;
      }
    </style>
  </head>
  <body class="bg-gray-100 text-gray-900">

    {/* Hero 区域 */}
    <section class="px-6 py-20 bg-white">
      <div class="max-w-3xl mx-auto">
        <a href="/" class="font-mono text-blue-600 font-bold mb-6 inline-block hover:underline">← 返回首页</a>
        <div class="flex flex-wrap gap-2 mb-6">
          <span class={`${project.data.status === '进行中' ? 'tag' : 'tag-secondary'} font-mono text-sm`}>
            {project.data.status}
          </span>
          {project.data.techStack.map((tech) => (
            <span class="border border-gray-400 px-2 py-1 text-xs font-mono">{tech}</span>
          ))}
        </div>
        <h1 class="font-mono text-4xl md:text-5xl font-bold mb-4">{project.data.title}</h1>
        <p class="text-xl text-gray-600 mb-8 leading-relaxed">{project.data.description}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          {project.data.demoUrl && (
            <BrutalButton href={project.data.demoUrl} variant="primary" size="md">
              查看演示 →
            </BrutalButton>
          )}
          {project.data.repoUrl && (
            <BrutalButton href={project.data.repoUrl} variant="secondary" size="md">
              查看代码 →
            </BrutalButton>
          )}
        </div>
      </div>
    </section>

    {/* 项目内容 */}
    <section class="px-6 py-16">
      <div class="max-w-3xl mx-auto">
        <BrutalCard class="p-8">
          <div class="prose prose-lg max-w-none">
            <p class="text-gray-700 leading-relaxed mb-6">
              项目详情内容正在整理中...
            </p>
            <p class="text-gray-600 text-sm font-mono">
              发布于 {project.data.publishDate.toLocaleDateString('zh-CN')}
              {project.data.updatedDate && ` · 更新于 ${project.data.updatedDate.toLocaleDateString('zh-CN')}`}
            </p>
          </div>
        </BrutalCard>
      </div>
    </section>

    {/* Footer */}
    <footer class="px-6 py-10 bg-gray-900 text-white text-center">
      <p class="font-mono">hione.one © 2026</p>
      <p class="text-gray-400 text-sm mt-2">Made with vibe coding 🦞</p>
    </footer>

  </body>
</html>
