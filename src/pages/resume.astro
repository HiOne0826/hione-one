---
import BrutalButton from '../components/ui/BrutalButton.astro';
import BrutalCard from '../components/ui/BrutalCard.astro';
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>高一 - 简历</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      .font-mono {
        font-family: 'JetBrains Mono', monospace;
      }
    </style>
  </head>
  <body class="bg-gray-100 text-gray-900">
    <section class="px-6 py-20 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="flex justify-between items-start mb-8">
          <div>
            <h1 class="font-mono text-4xl font-bold mb-2">高一</h1>
            <div class="text-gray-600 space-y-1">
              <p>📍 所在地：上海</p>
              <p>📧 邮箱：gaoe_2020@163.com</p>
              <p>🎓 河北经贸大学 · 朝鲜语 · 本科 (2018-2022)</p>
            </div>
          </div>
          <BrutalButton variant="primary" size="md">
            下载 PDF →
          </BrutalButton>
        </div>

        <BrutalCard class="p-8">
          <!-- 个人总结 -->
          <div class="mb-10">
            <h2 class="font-mono text-2xl font-bold mb-4 pb-2 border-b-3 border-gray-900">个人总结 / 核心优势</h2>
            <p class="text-gray-700 leading-relaxed">
              4 年 B2B SaaS 企业深耕经验。精准理解营销、制造、餐饮等 10+ 行业的业务逻辑与组织痛点，擅长拆解企业非标需求，将模糊的业务痛点转化为可落地的 <strong class="font-mono">Agent 工作流</strong> 与 <strong class="font-mono">Prompt 架构</strong>。
            </p>
            <p class="text-gray-700 leading-relaxed mt-3">
              具备 Dify、Coze、Aily、Claude Code 等多平台 Agent 开发经验，能独立构建 <strong class="font-mono">MVP</strong> 验证业务价值。具备从需求定义到部署落地的全链路项目管理能力，致力于通过 <strong class="font-mono">Vibe Coding</strong> 与 <strong class="font-mono">AI-Native</strong> 思维，帮助企业实现从"工具替代"到"业务重构"的跨越。
            </p>
          </div>

          <!-- 工作经历 -->
          <div class="mb-10">
            <h2 class="font-mono text-2xl font-bold mb-6 pb-2 border-b-3 border-gray-900">工作经历</h2>

            <!-- 北京飞鲸智云 -->
            <div class="mb-8">
              <div class="flex justify-between items-start mb-3">
                <div>
                  <h3 class="font-mono text-xl font-bold">北京飞鲸智云</h3>
                  <p class="text-gray-600 font-mono">飞书企业效能顾问</p>
                </div>
                <span class="font-mono text-sm text-gray-500 bg-gray-200 px-3 py-1">2023.07 - 至今</span>
              </div>
              <ul class="space-y-3 text-gray-700">
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">业务逻辑建模：</strong>深入 10+ 行业主导 120+ 企业客户数字化现状诊断。擅长将碎片化业务流抽象为标准化的数据模型与协作链路，累计输出 <strong class="font-mono">30+ 份深度企业业务调研报告</strong>。
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">AI 场景化交付：</strong>在 120+ 客户服务链路中，精准识别 <strong class="font-mono">10+ 个高价值 AI 场景需求</strong>。基于飞书智能体平台、多维表格等工具，实现从需求定义到 Prompt 调优、工作流配置再到最终业务提效的闭环交付。
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">商业价值实现：</strong>通过"产品+方案"双驱动，实现个人服务 <strong class="font-mono">ARR 800w</strong>。其中通过 AI 解决方案（BI 自动化、知识大脑等）实现 <strong class="font-mono">AI 专项 ARR 80w</strong>，覆盖 30+ 标杆客户。
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">内外部赋能：</strong>提炼并输出 20+ 个可规模化的 AI+ 业务最佳实践。面向 300+ 外部客户进行产品布道，有效降低了客户对复杂 AI 产品的采纳门槛。
                  </div>
                </li>
              </ul>
            </div>

            <!-- Treelab -->
            <div>
              <div class="flex justify-between items-start mb-3">
                <div>
                  <h3 class="font-mono text-xl font-bold">Treelab</h3>
                  <p class="text-gray-600 font-mono">用户运营</p>
                </div>
                <span class="font-mono text-sm text-gray-500 bg-gray-200 px-3 py-1">2021.10 - 2023.05</span>
              </div>
              <ul class="space-y-3 text-gray-700">
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">业务场景产品化：</strong>负责无代码产品在 0-1 阶段的场景定义，将客户需求沉淀为 40+ 份可落地的解决方案与产品手册，有效降低非技术用户上手门槛。
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">PLG 驱动增长：</strong>从 0 到 1 搭建用户社区，通过对用户反馈的深度闭环管理推动多个核心功能上线，实现 25% 的有效触达转化。
                  </div>
                </li>
              </ul>
            </div>
          </div>

          <!-- 项目经历 -->
          <div class="mb-10">
            <h2 class="font-mono text-2xl font-bold mb-6 pb-2 border-b-3 border-gray-900">项目经历</h2>

            <!-- 短视频洞察系统 -->
            <div class="mb-8">
              <div class="flex justify-between items-start mb-3">
                <h3 class="font-mono text-xl font-bold">基于 OpenClaw 的短视频洞察系统</h3>
                <span class="font-mono text-sm text-gray-500 bg-gray-200 px-3 py-1">2024.02 - 2024.03</span>
              </div>
              <ul class="space-y-3 text-gray-700">
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">项目背景：</strong>短视频内容复盘极度依赖人工拆解，存在分析维度单一、响应周期长、无法规模化提取"爆款基因"的痛点。
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">多智能体编排：</strong>基于 OpenClaw 框架设计协作流，将任务解构为视觉特征提取、语音转译、营销逻辑分类等独立 Agent 协同运行。
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">知识工程 (RAG)：</strong>构建垂直行业方法论向量库，通过 <strong class="font-mono">HyDE</strong> 优化检索质量，解决 AI 分析时的行业上下文缺失问题。
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">项目成果：</strong>单条视频深度分析从 45 分钟降至 <strong class="font-mono">3 分钟</strong>。自动化分析 50+ 竞品视频，提炼 10 个高转化内容模型。
                  </div>
                </li>
              </ul>
            </div>

            <!-- B 端即时 BI 解决方案 -->
            <div>
              <div class="flex justify-between items-start mb-3">
                <h3 class="font-mono text-xl font-bold">基于 LLM + MCP 协议的 B 端即时 BI 解决方案</h3>
                <span class="font-mono text-sm text-gray-500 bg-gray-200 px-3 py-1">2025.08 - 2025.11</span>
              </div>
              <ul class="space-y-3 text-gray-700">
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">项目背景：</strong>传统 BI 响应业务即时需求慢，数据获取依赖高，决策反馈周期长达数日。
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">架构设计：</strong>设计 <strong class="font-mono">Text-to-SQL + 可视化渲染</strong> 的闭环工作流。利用 <strong class="font-mono">Prompt Chaining</strong> 将复杂查询拆解为多步子任务。通过 <strong class="font-mono">MCP 协议</strong> 实现 LLM 与企业内部数据库的安全对接，有效解决模型在跨表查询中的逻辑幻觉问题。
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="font-mono text-lg mr-2 mt-0.5">▸</span>
                  <div>
                    <strong class="font-mono">项目成果：</strong>自动化处理 80% 重复性查询，数据交付从"天级"缩减至"秒级"，数据获取效率提升 <strong class="font-mono">60%</strong>，实现"对话即分析"。
                  </div>
                </li>
              </ul>
            </div>
          </div>

          <!-- 核心技能 -->
          <div>
            <h2 class="font-mono text-2xl font-bold mb-6 pb-2 border-b-3 border-gray-900">核心技能</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="border-3 border-gray-900 bg-white p-4">
                <h3 class="font-mono text-lg font-bold mb-2">AI 编排与架构</h3>
                <p class="text-gray-600 text-sm">精通 Coze、Dify、OpenClaw 等框架；擅长基于 RAG 架构优化垂直行业知识库的检索精度。</p>
              </div>
              <div class="border-3 border-gray-900 bg-white p-4">
                <h3 class="font-mono text-lg font-bold mb-2">AI 原生开发</h3>
                <p class="text-gray-600 text-sm">熟练运用 LLM 辅助进行 MVP 快速原型开发；具备 API 串联、数据清洗及 Text-to-SQL 实战经验。</p>
              </div>
              <div class="border-3 border-gray-900 bg-white p-4">
                <h3 class="font-mono text-lg font-bold mb-2">B 端业务数字化</h3>
                <p class="text-gray-600 text-sm">深耕 Feishu aPaaS、Treelab 等低代码平台；具备复杂业务流程的结构化建模与工作流设计能力。</p>
              </div>
              <div class="border-3 border-gray-900 bg-white p-4">
                <h3 class="font-mono text-lg font-bold mb-2">提示词工程</h3>
                <p class="text-gray-600 text-sm">擅长 Prompt Chaining 与 Few-shot 调优，能将业务规则精准转化为模型可执行的结构化指令集。</p>
              </div>
            </div>
          </div>
        </BrutalCard>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-6 py-10 bg-gray-900 text-white text-center">
      <p class="font-mono">hione.one © 2026</p>
      <p class="text-gray-400 text-sm mt-2">Made with vibe coding 🦞</p>
    </footer>
  </body>
</html>

<style is:global>
  .border-b-3 {
    border-bottom-width: 3px;
  }
  .border-3 {
    border-width: 3px;
  }
</style>
