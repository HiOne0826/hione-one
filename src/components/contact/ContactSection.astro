---
import BrutalButton from '../ui/BrutalButton.astro';
import BrutalCard from '../ui/BrutalCard.astro';
---

<section class="px-6 py-20 bg-white">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-mono text-3xl font-bold mb-8 text-center">联系我</h2>

    <!-- 联系表单 -->
    <BrutalCard class="mb-10">
      <form class="space-y-6">
        <div>
          <label class="font-mono font-bold block mb-2">姓名</label>
          <input type="text" class="w-full border-3 border-gray-900 p-3 font-mono bg-white" placeholder="请输入您的姓名">
        </div>
        <div>
          <label class="font-mono font-bold block mb-2">邮箱</label>
          <input type="email" class="w-full border-3 border-gray-900 p-3 font-mono bg-white" placeholder="请输入您的邮箱">
        </div>
        <div>
          <label class="font-mono font-bold block mb-2">留言</label>
          <textarea rows="5" class="w-full border-3 border-gray-900 p-3 font-mono bg-white" placeholder="请输入您想说的..."></textarea>
        </div>
        <BrutalButton variant="primary" size="lg" class="w-full">
          发送留言 →
        </BrutalButton>
      </form>
    </BrutalCard>

    <!-- 社交媒体链接 -->
    <div class="text-center">
      <p class="text-gray-600 mb-4 font-mono">或者通过社交媒体找到我：</p>
      <div class="flex justify-center gap-6 flex-wrap">
        <BrutalButton variant="secondary" size="md">
          X / Twitter
        </BrutalButton>
        <BrutalButton variant="secondary" size="md">
          GitHub
        </BrutalButton>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .border-3 {
    border-width: 3px;
  }
</style>
