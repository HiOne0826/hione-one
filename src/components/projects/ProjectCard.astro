---
import BrutalButton from '../ui/BrutalButton.astro';
import BrutalCard from '../ui/BrutalCard.astro';
import Tag from '../ui/Tag.astro';

interface Props {
  title: string;
  description: string;
  status: '进行中' | '已完成';
  techStack: string[];
  image?: string;
  href?: string;
}

const { title, description, status, techStack, image, href } = Astro.props;
---

<BrutalCard>
  <div class="flex justify-between items-start mb-4">
    <h3 class="font-mono text-xl font-bold">{title}</h3>
    <Tag active={status === '进行中'}>{status}</Tag>
  </div>
  <p class="text-gray-600 mb-4 leading-relaxed">{description}</p>
  <div class="flex flex-wrap gap-2 mb-6">
    {techStack.map((tech) => (
      <span class="border border-gray-400 px-2 py-1 text-xs font-mono">{tech}</span>
    ))}
  </div>
  {href && (
    <BrutalButton href={href} variant="primary" size="sm">
      查看详情 →
    </BrutalButton>
  )}
</BrutalCard>
