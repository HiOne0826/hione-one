---
import { getCollection } from 'astro:content';
import Tag from '../ui/Tag.astro';
import BrutalButton from '../ui/BrutalButton.astro';

const blogs = await getCollection('blog');
const micros = await getCollection('micro');
const videos = await getCollection('video');
---

<section class="px-6 py-20 bg-gray-100">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-mono text-3xl font-bold mb-8">内容</h2>

    <!-- 标签页 -->
    <div class="flex gap-4 mb-10">
      <Tag active>博客</Tag>
      <Tag>碎碎念</Tag>
      <Tag>视频</Tag>
    </div>

    <!-- 博客内容 -->
    <div class="mb-10">
      {blogs.length > 0 ? (
        <div class="space-y-8">
          {blogs.slice(0, 2).map((blog) => (
            <div class="pb-8 border-b-2 border-gray-300">
              <div class="flex gap-2 mb-3">
                {blog.data.tags.map((tag) => (
                  <span class="border-2 border-gray-900 bg-blue-600 text-white px-3 py-1 font-mono text-xs">#{tag}</span>
                ))}
              </div>
              <h3 class="font-mono text-xl font-bold mb-2">{blog.data.title}</h3>
              <p class="font-mono text-sm text-gray-500 mb-3">
                {blog.data.publishDate.toLocaleDateString('zh-CN')} · 阅读时间 8 分钟
              </p>
              <p class="text-gray-700 mb-4">{blog.data.description}</p>
              <a href={`/content/blog/${blog.id}`} class="font-mono text-blue-600 font-bold">阅读全文 →</a>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-500 font-mono">暂无博客内容，敬请期待...</p>
      )}

      {blogs.length > 0 && (
        <div class="mt-6">
          <BrutalButton href="/content/blog" variant="secondary" size="md">
            查看全部博客 →
          </BrutalButton>
        </div>
      )}
    </div>

    <!-- 碎碎念内容 -->
    <div class="mb-10">
      {micros.length > 0 ? (
        <div class="space-y-6">
          {micros.slice(0, 5).map((micro) => (
            <div class="pb-6 border-b-2 border-gray-300">
              <p class="font-mono text-sm text-gray-500 mb-2">
                {micro.data.publishDate.toLocaleDateString('zh-CN')} {micro.data.publishDate.toLocaleTimeString('zh-CN', {hour: '2-digit', minute: '2-digit'})}
              </p>
              <p class="text-gray-700">{micro.data.content}</p>
              {micro.data.tags && micro.data.tags.length > 0 && (
                <div class="mt-3 flex gap-2">
                  {micro.data.tags.map((tag) => (
                    <span class="border border-gray-400 px-2 py-0.5 text-xs font-mono">#{tag}</span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-500 font-mono">暂无碎碎念...</p>
      )}

      {micros.length > 0 && (
        <div class="mt-6">
          <BrutalButton href="/content/micro" variant="secondary" size="md">
            查看全部碎碎念 →
          </BrutalButton>
        </div>
      )}
    </div>

    <!-- 视频内容 -->
    <div class="mb-10">
      {videos.length > 0 ? (
        <div class="space-y-6">
          {videos.slice(0, 3).map((video) => (
            <div>
              <h3 class="font-mono text-lg font-bold mb-2">{video.data.title}</h3>
              <p class="text-gray-600 mb-3">{video.data.description}</p>
              <span class="border border-gray-400 px-2 py-1 text-xs font-mono">{video.data.platform}</span>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-500 font-mono">暂无视频内容...</p>
      )}

      {videos.length > 0 && (
        <div class="mt-6">
          <BrutalButton href="/content/video" variant="secondary" size="md">
            查看全部视频 →
          </BrutalButton>
        </div>
      )}
    </div>
  </div>
</section>

<style is:global>
  .border-b-2 {
    border-bottom-width: 2px;
  }
  .border-2 {
    border-width: 2px;
  }
</style>
