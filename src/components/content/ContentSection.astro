---
import { getCollection } from 'astro:content';
import Tag from '../ui/Tag.astro';
import BrutalButton from '../ui/BrutalButton.astro';

const blogs = await getCollection('blog');
---

<section class="px-6 py-20 bg-gray-100">
  <div class="max-w-3xl mx-auto">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
      <h2 class="font-mono text-3xl font-bold">内容</h2>
      {blogs.length > 0 && (
        <BrutalButton href="/content" variant="secondary" size="md">
          查看全部 →
        </BrutalButton>
      )}
    </div>

    {/* 博客内容 */}
    {blogs.length > 0 ? (
      <div>
        {/* 所有博客（隐藏的） */}
        <div id="all-blogs" style="display: none;">
          {blogs.map((blog, index) => (
            <div class="pb-8 border-b-2 border-gray-300 blog-item" data-index={index} data-tags={JSON.stringify(blog.data.tags)} data-title={blog.data.title} data-date={blog.data.publishDate.toLocaleDateString('zh-CN')} data-description={blog.data.description} data-href={`/content/blog/${blog.id}`}></div>
          ))}
        </div>

        {/* 当前页显示的博客 */}
        <div id="blog-items" class="space-y-8"></div>

        {/* 分页按钮 */}
        {blogs.length > 2 && (
          <div class="mt-8 flex justify-center gap-4">
            <button id="prev-btn" class="brutal-btn px-6 py-2 bg-white font-mono font-bold disabled:opacity-50" disabled>
              ← 上一页
            </button>
            <span id="page-info" class="font-mono text-gray-600 self-center">1 / {Math.ceil(blogs.length / 2)}</span>
            <button id="next-btn" class="brutal-btn px-6 py-2 bg-white font-mono font-bold">
              下一页 →
            </button>
          </div>
        )}
      </div>
    ) : (
      <p class="text-gray-500 font-mono">暂无博客内容，敬请期待...</p>
    )}
  </div>
</section>

<style is:global>
  .border-b-2 {
    border-bottom-width: 2px;
  }
  .border-2 {
    border-width: 2px;
  }
</style>

<script is:inline>
  // 首页内容分页
  const itemsPerPage = 2;
  let currentPage = 1;
  
  // 从隐藏元素中获取博客数据
  const blogItems = Array.from(document.querySelectorAll('.blog-item')).map(item => ({
    tags: JSON.parse(item.dataset.tags),
    title: item.dataset.title,
    date: item.dataset.date,
    description: item.dataset.description,
    href: item.dataset.href
  }));
  
  const totalPages = Math.ceil(blogItems.length / itemsPerPage);

  const blogItemsContainer = document.getElementById('blog-items');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const pageInfo = document.getElementById('page-info');

  function renderBlogs() {
    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    const pageBlogs = blogItems.slice(start, end);

    blogItemsContainer.innerHTML = pageBlogs.map((blog) => `
      <div class="pb-8 border-b-2 border-gray-300">
        <div class="flex gap-2 mb-3">
          ${blog.tags.map(tag => `<span class="border-2 border-gray-900 bg-blue-600 text-white px-3 py-1 font-mono text-xs">#${tag}</span>`).join('')}
        </div>
        <h3 class="font-mono text-xl font-bold mb-2">${blog.title}</h3>
        <p class="font-mono text-sm text-gray-500 mb-3">${blog.date} · 阅读时间 8 分钟</p>
        <p class="text-gray-700 mb-4">${blog.description}</p>
        <a href="${blog.href}" class="font-mono text-blue-600 font-bold">阅读全文 →</a>
      </div>
    `).join('');

    // 更新分页按钮状态
    if (prevBtn) prevBtn.disabled = currentPage === 1;
    if (nextBtn) nextBtn.disabled = currentPage === totalPages;
    if (pageInfo) pageInfo.textContent = `${currentPage} / ${totalPages}`;
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        renderBlogs();
      }
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      if (currentPage < totalPages) {
        currentPage++;
        renderBlogs();
      }
    });
  }

  // 初始渲染
  if (blogItems.length > 0) {
    renderBlogs();
  }
</script>
