---
import BrutalButton from '../ui/BrutalButton.astro';
---

<section class="min-h-screen flex flex-col justify-center items-center px-6 py-20 bg-gradient-to-br from-gray-100 via-gray-200 to-gray-100"
         style="background-image: linear-gradient(rgba(0,0,0,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.03) 1px, transparent 1px); background-size: 20px 20px;">
  <div class="max-w-2xl w-full">
    <h1 class="font-mono text-5xl font-bold mb-6">Eric Gao</h1>
    <p class="text-xl text-gray-600 mb-8 leading-relaxed">
      创业者 / vibe coder<br>
      从飞书 CSM 到 AI 创业，正在做抖音数据 AI 分析
    </p>
    <div class="flex flex-col sm:flex-row gap-4">
      <BrutalButton href="/resume" variant="secondary" size="md">
        看我的简历 →
      </BrutalButton>
      <BrutalButton href="/agent" variant="primary" size="md">
        Agent 专区 🚧
      </BrutalButton>
    </div>
  </div>
</section>
